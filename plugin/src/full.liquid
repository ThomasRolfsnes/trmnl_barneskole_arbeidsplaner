{% if available %}
  <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:#fff;">
    <img src="{{ image_url }}"
         style="max-width:100%;max-height:100%;width:auto;height:auto;display:block;"
         alt="{{ school_name }} {{ trinn_label }} {{ title }}" />
  </div>
{% else %}
  <div class="layout layout--col" style="height:100%;align-items:center;justify-content:center;text-align:center;">
    <span class="title">{{ trinn_label }}</span>
    <span class="description">Ingen arbeidsplan publisert ennå</span>
    <span class="label label--gray-out">{{ school_name }}</span>
  </div>
{% endif %}
